{
  "manifest_version": 3,
  "name": "TwitchNoAds",
  "version": "1.0",
  "description": "Swaps the ad video with an ad-free stream.",
  "permissions": [],
  "host_permissions": [
    "*://*.twitch.tv/*",
    "https://raw.githubusercontent.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["src/scripts/video-swap-new.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_popup": "src/popup.html"
  },
  "icons": {
    "16": "src/icons/icon16.png",
    "48": "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  }
}
