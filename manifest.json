{
  "manifest_version": 3,
  "name": "TwitchFreeTurbo",
  "version": "1.0",
  "description": "Swaps the ad video with the stream preview and swaps audio during Twitch ads.",
  "permissions": ["storage"],
  "host_permissions": ["*://*.twitch.tv/*"],
  "content_scripts": [
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["src/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/scripts/bypass.js"],
      "matches": ["*://*.twitch.tv/*"]
    }
  ],
  "icons": {
    "16": "src/icons/icon16.png",
    "48": "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  }
}
