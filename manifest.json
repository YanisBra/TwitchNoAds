{
  "manifest_version": 3,
  "name": "TwitchNoAds",
  "version": "2.3",
  "description": "Swaps the ad video with an ad-free stream.",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.twitch.tv/*",
    "https://raw.githubusercontent.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["src/scripts/video-swap.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["src/scripts/content-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["src/scripts/player-controls.js", "src/scripts/channel-points.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "icons": {
    "16": "src/icons/icon16.png",
    "48": "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/assets/live.png", "src/assets/rewind.png"],
      "matches": ["*://*.twitch.tv/*"]
    }
  ]
}
